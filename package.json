{
  "name": "ai-book-saas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint --fix",
    "diagnose:processing": "node --env-file=.env.local scripts/diagnose-processing.mjs",
    "diagnose:extraction": "node --env-file=.env.local scripts/verify-latest-extraction.mjs",
    "diagnose:ocr": "node --experimental-strip-types --env-file=.env.local scripts/verify-latest-extraction.mjs --ocr",
    "reprocess:document": "node --env-file=.env.local --import tsx scripts/reprocess-document.ts",
    "test:rag": "node --env-file=.env.local --import tsx scripts/smoke-rag.ts",
    "test:providers": "node --env-file=.env.local scripts/smoke-providers.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.2",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@langchain/pinecone": "^1.0.3",
    "@pinecone-database/pinecone": "^5.0.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.2.4",
    "next": "^16.2.9",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^7.3.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
